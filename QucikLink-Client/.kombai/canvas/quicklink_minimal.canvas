    "var_c0558acbf102": {
      "type": "variant",
      "label": "QuickLink — Minimal Dark Lookup",
      "parentId": "var_e934e946e388",
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1280,
        "h": 866
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap');\n</style>\n<script src=\"https://unpkg.com/lucide@latest\">\n</script>\n<div class=\"bg-[#151515] font-['Source_Sans_3'] text-[#F4F4F4] antialiased\" data-kid=\"1\">\n    <!-- NAVBAR (identical to home/login) -->\n    <nav class=\"max-w-[1120px] mx-auto px-6 py-5 flex items-center justify-between\" data-kid=\"1-1\">\n        <a class=\"flex items-center gap-2.5\" data-kid=\"1-1-1\" href=\"#\">\n            <span class=\"w-8 h-8 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[16px]\" data-kid=\"1-1-1-1\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-1-1-1\" data-lucide=\"link-2\">\n                </i>\n            </span>\n            <span class=\"font-[Manrope] font-bold text-[18px] tracking-tight text-[#F4F4F4]\" data-kid=\"1-1-1-2\">\n                QuickLink\n            </span>\n        </a>\n        <div class=\"flex items-center gap-6\" data-kid=\"1-1-2\">\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-1\" href=\"#\">\n                Shorten\n            </a>\n            <a class=\"text-[14px] text-[#F4F4F4] font-semibold\" data-kid=\"1-1-2-2\" href=\"#\">\n                Analytics\n            </a>\n            <a class=\"text-[14px] text-[#D4D4D4] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-3\" href=\"#\">\n                Log in\n            </a>\n            <button aria-label=\"Toggle theme\" class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-1-2-4\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-2-4-1\" data-lucide=\"sun\">\n                </i>\n            </button>\n            <button class=\"rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[14px] px-4 py-2\" data-kid=\"1-1-2-5\">\n                Sign up\n            </button>\n        </div>\n    </nav>\n    <main data-kid=\"1-2\">\n        <!-- LOOKUP SECTION -->\n        <section class=\"max-w-[680px] mx-auto px-6 pt-16 pb-14 text-center\" data-kid=\"1-2-1\">\n            <h1 class=\"font-[Manrope] font-extrabold text-[36px] leading-[1.15] tracking-tight text-[#F4F4F4]\" data-kid=\"1-2-1-1\">\n                How is your link doing?\n            </h1>\n            <p class=\"mt-3 text-[15px] leading-relaxed text-[#969696] max-w-md mx-auto\" data-kid=\"1-2-1-2\">\n                Enter a short code or alias to see its destination and click counts.\n            </p>\n            <!-- SEARCH ROW -->\n            <div class=\"mt-8 h-14 rounded-full bg-[#171717] border border-[#2C2C2C] flex items-center pl-5 pr-1.5 focus-within:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-3\">\n                <span class=\"text-[#6B6B6B] text-[16px] flex items-center shrink-0\" data-kid=\"1-2-1-3-1\">\n                    <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-1-1\" data-lucide=\"search\">\n                    </i>\n                </span>\n                <input class=\"flex-1 min-w-0 bg-transparent px-3 text-[15px] font-['JetBrains_Mono'] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none\" data-kid=\"1-2-1-3-2\" data-name=\"link lookup input field\" placeholder=\"quicklink.live/summer-sale\" type=\"text\"/>\n                <button class=\"shrink-0 inline-flex items-center gap-2 h-11 rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[14px] px-5\" data-kid=\"1-2-1-3-3\">\n                    <span data-kid=\"1-2-1-3-3-1\">\n                        Inspect\n                    </span>\n                    <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-3-2\" data-lucide=\"arrow-right\">\n                    </i>\n                </button>\n            </div>\n            <!-- RESULT PANEL (filled state) -->\n            <div class=\"mt-6 text-left bg-[#1E1E1E] border border-[#2C2C2C] rounded-[24px] p-6\" data-kid=\"1-2-1-4\">\n                <!-- Top: short link + actions -->\n                <div class=\"flex items-start justify-between gap-4\" data-kid=\"1-2-1-4-1\">\n                    <div class=\"min-w-0\" data-kid=\"1-2-1-4-1-1\">\n                        <span class=\"block text-[13px] text-[#969696]\" data-kid=\"1-2-1-4-1-1-1\">\n                            Short link\n                        </span>\n                        <span class=\"mt-1 block font-['JetBrains_Mono'] font-semibold text-[20px] text-[#2DD4BF] truncate\" data-dynamic=\"true\" data-kid=\"1-2-1-4-1-1-2\" data-name=\"shortened link URL display\" data-reason=\"text content updated dynamically after link lookup\">\n                            quicklink.live/summer-sale\n                        </span>\n                    </div>\n                    <div class=\"flex items-center gap-2 shrink-0 pt-1\" data-kid=\"1-2-1-4-1-2\">\n                        <button class=\"inline-flex items-center gap-2 rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[13px] px-3.5 py-1.5\" data-kid=\"1-2-1-4-1-2-1\">\n                            <i class=\"w-3.5 h-3.5\" data-kid=\"1-2-1-4-1-2-1-1\" data-lucide=\"copy\">\n                            </i>\n                            <span data-kid=\"1-2-1-4-1-2-1-2\">\n                                Copy\n                            </span>\n                        </button>\n                        <button aria-label=\"Open short link\" class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-2-1-4-1-2-2\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-4-1-2-2-1\" data-lucide=\"external-link\">\n                            </i>\n                        </button>\n                    </div>\n                </div>\n                <!-- Destination -->\n                <div class=\"mt-4 pt-4 border-t border-[#2C2C2C] flex items-center gap-2\" data-kid=\"1-2-1-4-2\">\n                    <span class=\"text-[#6B6B6B] text-[14px] flex items-center shrink-0\" data-kid=\"1-2-1-4-2-1\">\n                        <i class=\"w-3.5 h-3.5\" data-kid=\"1-2-1-4-2-1-1\" data-lucide=\"arrow-right\">\n                        </i>\n                    </span>\n                    <span class=\"font-['JetBrains_Mono'] text-[13px] text-[#D4D4D4] truncate\" data-dynamic=\"true\" data-kid=\"1-2-1-4-2-2\" data-name=\"original destination URL display\" data-reason=\"text content updated dynamically after link lookup\">\n                        https://example.com/summer-sale\n                    </span>\n                </div>\n                <!-- Metrics: plain typographic stats, no tiles -->\n                <div class=\"mt-4 pt-4 border-t border-[#2C2C2C] grid grid-cols-3 divide-x divide-[#2C2C2C] text-center\" data-kid=\"1-2-1-4-3\">\n                    <div class=\"px-4\" data-kid=\"1-2-1-4-3-1\">\n                        <span class=\"block font-[Manrope] font-bold text-[18px] text-[#F4F4F4]\" data-dynamic=\"true\" data-kid=\"1-2-1-4-3-1-1\" data-name=\"total clicks statistic value\" data-reason=\"number updated dynamically by analytics fetch\">\n                            1,248\n                        </span>\n                        <span class=\"mt-0.5 block text-[13px] text-[#969696]\" data-kid=\"1-2-1-4-3-1-2\">\n                            Total clicks\n                        </span>\n                    </div>\n                    <div class=\"px-4\" data-kid=\"1-2-1-4-3-2\">\n                        <span class=\"block font-[Manrope] font-bold text-[18px] text-[#F4F4F4]\" data-dynamic=\"true\" data-kid=\"1-2-1-4-3-2-1\" data-name=\"link creation date display\" data-reason=\"text content updated dynamically by analytics fetch\">\n                            Jul 2, 2026\n                        </span>\n                        <span class=\"mt-0.5 block text-[13px] text-[#969696]\" data-kid=\"1-2-1-4-3-2-2\">\n                            Created\n                        </span>\n                    </div>\n                    <div class=\"px-4\" data-kid=\"1-2-1-4-3-3\">\n                        <span class=\"block font-[Manrope] font-bold text-[18px] text-[#F4F4F4]\" data-dynamic=\"true\" data-kid=\"1-2-1-4-3-3-1\" data-name=\"link expiration status\" data-reason=\"text content updated dynamically by analytics fetch\">\n                            Never\n                        </span>\n                        <span class=\"mt-0.5 block text-[13px] text-[#969696]\" data-kid=\"1-2-1-4-3-3-2\">\n                            Expires\n                        </span>\n                    </div>\n                </div>\n                <!-- QR row -->\n                <div class=\"mt-4 pt-4 border-t border-[#2C2C2C] flex items-center justify-between gap-4\" data-kid=\"1-2-1-4-4\">\n                    <div data-kid=\"1-2-1-4-4-1\">\n                        <h3 class=\"font-[Manrope] font-semibold text-[15px] text-[#F4F4F4]\" data-kid=\"1-2-1-4-4-1-1\">\n                            QR code\n                        </h3>\n                        <p class=\"mt-0.5 text-[13px] text-[#969696]\" data-kid=\"1-2-1-4-4-1-2\">\n                            Scan to open the short link.\n                        </p>\n                        <button class=\"mt-3 inline-flex items-center gap-2 rounded-full border border-[#2C2C2C] hover:border-[#969696] transition-colors text-[#D4D4D4] font-medium text-[13px] px-3.5 py-1.5\" data-kid=\"1-2-1-4-4-1-3\">\n                            <i class=\"w-3.5 h-3.5\" data-kid=\"1-2-1-4-4-1-3-1\" data-lucide=\"download\">\n                            </i>\n                            <span data-kid=\"1-2-1-4-4-1-3-2\">\n                                Download PNG\n                            </span>\n                        </button>\n                    </div>\n                    <div class=\"bg-white p-2 rounded-2xl shrink-0\" data-kid=\"1-2-1-4-4-2\">\n                        <img alt=\"QR code for quicklink.live/summer-sale\" class=\"w-20 h-20\" data-dynamic=\"true\" data-kid=\"1-2-1-4-4-2-1\" data-name=\"link QR code image\" data-reason=\"image source reinitialized dynamically based on lookup result\" decoding=\"async\" loading=\"lazy\" src=\"https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=https://quicklink.live/summer-sale\"/>\n                    </div>\n                </div>\n            </div>\n            <!-- Empty-state hint -->\n            <p class=\"mt-6 text-center text-[13px] text-[#6B6B6B]\" data-kid=\"1-2-1-5\">\n                Expired links stop redirecting automatically.\n            </p>\n        </section>\n    </main>\n    <!-- FOOTER (identical to home/login) -->\n    <footer class=\"border-t border-[#2C2C2C]\" data-kid=\"1-3\">\n        <div class=\"max-w-[1120px] mx-auto px-6 py-6 flex items-center justify-between text-[13px] text-[#6B6B6B]\" data-kid=\"1-3-1\">\n            <div class=\"flex items-center gap-2\" data-kid=\"1-3-1-1\">\n                <span class=\"w-5 h-5 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[12px]\" data-kid=\"1-3-1-1-1\">\n                    <i class=\"w-3 h-3\" data-kid=\"1-3-1-1-1-1\" data-lucide=\"link-2\">\n                    </i>\n                </span>\n                <span class=\"font-[Manrope] font-semibold text-[#969696]\" data-kid=\"1-3-1-1-2\">\n                    QuickLink\n                </span>\n            </div>\n            <div class=\"flex items-center gap-5\" data-kid=\"1-3-1-2\">\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-1\" href=\"#\">\n                    Shorten\n                </a>\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-2\" href=\"#\">\n                    Analytics\n                </a>\n            </div>\n            <span data-kid=\"1-3-1-3\">\n                © 2026 QuickLink\n            </span>\n        </div>\n    </footer>\n</div>\n<script>\n    lucide.createIcons();\n</script>\n",
