# QuickLink Server Configuration
PORT=8080

# Neon PostgreSQL Database Credentials
DB_URL=jdbc:postgresql://<neon-db-hostname>/neondb?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=your_neon_db_password

# Upstash Redis Cache Credentials
REDIS_URL=your-redis-instance.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_redis_password

# JWT Authentication Secret
JWT_SECRET=your_secure_256bit_random_jwt_secret_key_here

# CORS Allowed Origins (Comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
