      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap');\n</style>\n<script src=\"https://unpkg.com/lucide@latest\">\n</script>\n<div class=\"bg-[#151515] font-['Source_Sans_3'] text-[#F4F4F4] antialiased\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- NAVBAR (identical to home) -->\n    <nav class=\"max-w-[1120px] mx-auto px-6 py-5 flex items-center justify-between\" data-kid=\"1-1\" data-name=\"main navigation bar\">\n        <a class=\"flex items-center gap-2.5\" data-kid=\"1-1-1\" data-name=\"brand logo and name link\" href=\"#\">\n            <span class=\"w-8 h-8 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[16px]\" data-kid=\"1-1-1-1\" data-name=\"brand logo icon container\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-1-1-1\" data-lucide=\"link-2\" data-name=\"link icon\">\n                </i>\n            </span>\n            <span class=\"font-[Manrope] font-bold text-[18px] tracking-tight text-[#F4F4F4]\" data-kid=\"1-1-1-2\" data-name=\"brand name text\">\n                QuickLink\n            </span>\n        </a>\n        <div class=\"flex items-center gap-6\" data-kid=\"1-1-2\" data-name=\"navigation links and action buttons container\">\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-1\" data-name=\"shorten navigation link\" href=\"#\">\n                Shorten\n            </a>\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-2\" data-name=\"analytics navigation link\" href=\"#\">\n                Analytics\n            </a>\n            <button class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-1-2-3\" data-name=\"theme toggle button\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-2-3-1\" data-lucide=\"sun\" data-name=\"sun icon\">\n                </i>\n            </button>\n            <a class=\"text-[14px] text-[#D4D4D4] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-4\" data-name=\"login navigation link\" href=\"#\">\n                Log in\n            </a>\n            <button class=\"rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[14px] px-4 py-2\" data-kid=\"1-1-2-5\" data-name=\"sign up button\">\n                Sign up\n            </button>\n        </div>\n    </nav>\n    <main data-kid=\"1-2\" data-name=\"main content area\">\n        <!-- LOGIN SECTION -->\n        <section class=\"max-w-[680px] mx-auto px-6 pt-20 pb-24\" data-kid=\"1-2-1\" data-name=\"login section\">\n            <div class=\"text-center\" data-kid=\"1-2-1-1\" data-name=\"login header group\">\n                <h1 class=\"font-[Manrope] font-extrabold text-[36px] tracking-tight text-[#F4F4F4]\" data-kid=\"1-2-1-1-1\" data-name=\"login headline\">\n                    Welcome back.\n                </h1>\n                <p class=\"mt-3 text-[15px] text-[#969696]\" data-kid=\"1-2-1-1-2\" data-name=\"login subheadline\">\n                    Log in to manage your links and see click counts.\n                </p>\n            </div>\n            <!-- LOGIN PANEL -->\n            <div class=\"mt-8 max-w-[420px] mx-auto bg-[#1E1E1E] border border-[#2C2C2C] rounded-[24px] p-7\" data-kid=\"1-2-1-2\" data-name=\"login panel container\">\n                <!-- Username -->\n                <div data-kid=\"1-2-1-2-1\" data-name=\"username input group\">\n                    <label class=\"block text-[13px] font-medium text-[#D4D4D4] mb-1.5\" data-kid=\"1-2-1-2-1-1\" data-name=\"username label\">\n                        Username\n                    </label>\n                    <div class=\"relative\" data-kid=\"1-2-1-2-1-2\" data-name=\"username input field container\">\n                        <span class=\"absolute left-5 top-1/2 -translate-y-1/2 text-[#6B6B6B] text-[16px] flex items-center\" data-kid=\"1-2-1-2-1-2-1\" data-name=\"username input icon container\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-2-1-2-1-1\" data-lucide=\"user\" data-name=\"user icon\">\n                            </i>\n                        </span>\n                        <input class=\"w-full h-12 rounded-full bg-[#171717] border border-[#2C2C2C] pl-12 pr-5 text-[15px] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none focus:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-2-1-2-2\" data-name=\"username input field\" placeholder=\"your-username\" type=\"text\"/>\n                    </div>\n                </div>\n                <!-- Password -->\n                <div class=\"mt-4\" data-kid=\"1-2-1-2-2\" data-name=\"password input group\">\n                    <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"1-2-1-2-2-1\" data-name=\"password header group\">\n                        <label class=\"block text-[13px] font-medium text-[#D4D4D4]\" data-kid=\"1-2-1-2-2-1-1\" data-name=\"password label\">\n                            Password\n                        </label>\n                        <a class=\"text-[13px] text-[#969696] hover:text-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-2-2-1-2\" data-name=\"forgot password link\" href=\"#\">\n                            Forgot?\n                        </a>\n                    </div>\n                    <div class=\"relative\" data-kid=\"1-2-1-2-2-2\" data-name=\"password input field container\">\n                        <span class=\"absolute left-5 top-1/2 -translate-y-1/2 text-[#6B6B6B] text-[16px] flex items-center\" data-kid=\"1-2-1-2-2-2-1\" data-name=\"password input icon container\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-2-2-2-1-1\" data-lucide=\"lock\" data-name=\"lock icon\">\n                            </i>\n                        </span>\n                        <input class=\"w-full h-12 rounded-full bg-[#171717] border border-[#2C2C2C] pl-12 pr-5 text-[15px] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none focus:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-2-2-2-2\" data-name=\"password input field\" placeholder=\"••••••••\" type=\"password\"/>\n                    </div>\n                </div>\n                <!-- CTA -->\n                <button class=\"mt-6 w-full h-12 rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[15px] flex items-center justify-center gap-2\" data-kid=\"1-2-1-2-3\" data-name=\"login submit button\">\n                    <span data-kid=\"1-2-1-2-3-1\" data-name=\"login button text\">\n                        Log in\n                    </span>\n                    <i class=\"w-4 h-4\" data-kid=\"1-2-1-2-3-2\" data-lucide=\"arrow-right\" data-name=\"arrow right icon\">\n                    </i>\n                </button>\n                <!-- Error state -->\n                <div class=\"mt-4 rounded-[16px] px-4 py-3 bg-red-500/10 border border-red-500/30 flex items-center gap-2 text-[13px] text-[#F87171]\" data-kid=\"1-2-1-2-4\" data-name=\"error message box\">\n                    <i class=\"w-4 h-4 shrink-0\" data-kid=\"1-2-1-2-4-1\" data-lucide=\"alert-circle\" data-name=\"alert icon\">\n                    </i>\n                    <span data-kid=\"1-2-1-2-4-2\" data-name=\"error message text\">\n                        Invalid username or password.\n                    </span>\n                </div>\n                <!-- Register footer -->\n                <div class=\"mt-6 pt-5 border-t border-[#2C2C2C] text-center text-[14px] text-[#969696]\" data-kid=\"1-2-1-2-5\" data-name=\"registration footer\">\n                    New to QuickLink?\n                    <a class=\"text-[#2DD4BF] font-medium hover:underline\" data-kid=\"1-2-1-2-5-1\" data-name=\"create account link\" href=\"#\">\n                        Create an account\n                    </a>\n                </div>\n            </div>\n            <p class=\"mt-6 text-center text-[13px] text-[#6B6B6B]\" data-kid=\"1-2-1-3\" data-name=\"helper text\">\n                No account needed to shorten links — just paste and go.\n            </p>\n        </section>\n    </main>\n    <!-- FOOTER (identical to home) -->\n    <footer class=\"border-t border-[#2C2C2C]\" data-kid=\"1-3\" data-name=\"footer section\">\n        <div class=\"max-w-[1120px] mx-auto px-6 py-6 flex items-center justify-between text-[13px] text-[#6B6B6B]\" data-kid=\"1-3-1\" data-name=\"footer content container\">\n            <div class=\"flex items-center gap-2\" data-kid=\"1-3-1-1\" data-name=\"footer brand container\">\n                <span class=\"w-5 h-5 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[12px]\" data-kid=\"1-3-1-1-1\" data-name=\"footer logo icon container\">\n                    <i class=\"w-3 h-3\" data-kid=\"1-3-1-1-1-1\" data-lucide=\"link-2\" data-name=\"link icon\">\n                    </i>\n                </span>\n                <span class=\"font-[Manrope] font-semibold text-[#969696]\" data-kid=\"1-3-1-1-2\" data-name=\"footer brand name text\">\n                    QuickLink\n                </span>\n            </div>\n            <div class=\"flex items-center gap-5\" data-kid=\"1-3-1-2\" data-name=\"footer navigation links container\">\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-1\" data-name=\"footer shorten link\" href=\"#\">\n                    Shorten\n                </a>\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-2\" data-name=\"footer analytics link\" href=\"#\">\n                    Analytics\n                </a>\n            </div>\n            <span data-kid=\"1-3-1-3\" data-name=\"copyright notice text\">\n                © 2026 QuickLink\n            </span>\n        </div>\n    </footer>\n</div>\n<script>\n    lucide.createIcons();\n</script>\n",
