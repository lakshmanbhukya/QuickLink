        "h": 925
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap');\n</style>\n<script src=\"https://unpkg.com/lucide@latest\">\n</script>\n<div class=\"bg-[#151515] font-['Source_Sans_3'] text-[#F4F4F4] antialiased\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- NAVBAR (identical to login node) -->\n    <nav class=\"max-w-[1120px] mx-auto px-6 py-5 flex items-center justify-between\" data-kid=\"1-1\" data-name=\"main navigation bar\">\n        <a class=\"flex items-center gap-2.5\" data-kid=\"1-1-1\" data-name=\"brand logo area\" href=\"#\">\n            <span class=\"w-8 h-8 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[16px]\" data-kid=\"1-1-1-1\" data-name=\"brand link icon container\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-1-1-1\" data-lucide=\"link-2\" data-name=\"link icon\">\n                </i>\n            </span>\n            <span class=\"font-[Manrope] font-bold text-[18px] tracking-tight text-[#F4F4F4]\" data-kid=\"1-1-1-2\" data-name=\"brand name text\">\n                QuickLink\n            </span>\n        </a>\n        <div class=\"flex items-center gap-6\" data-kid=\"1-1-2\" data-name=\"nav links container\">\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-1\" data-name=\"shorten nav link\" href=\"#\">\n                Shorten\n            </a>\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-2\" data-name=\"analytics nav link\" href=\"#\">\n                Analytics\n            </a>\n            <a class=\"text-[14px] text-[#D4D4D4] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-3\" data-name=\"login nav link\" href=\"#\">\n                Log in\n            </a>\n            <button class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-1-2-4\" data-name=\"theme toggle button\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-2-4-1\" data-lucide=\"sun\" data-name=\"sun icon\">\n                </i>\n            </button>\n            <button class=\"rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[14px] px-4 py-2\" data-kid=\"1-1-2-5\" data-name=\"sign up button\">\n                Sign up\n            </button>\n        </div>\n    </nav>\n    <main data-kid=\"1-2\" data-name=\"main content area\">\n        <!-- REGISTER SECTION -->\n        <section class=\"px-6 pt-20 pb-24\" data-kid=\"1-2-1\" data-name=\"registration section\">\n            <h1 class=\"font-[Manrope] font-extrabold text-[36px] leading-tight tracking-tight text-[#F4F4F4] text-center\" data-kid=\"1-2-1-1\" data-name=\"registration headline text\">\n                Create your account.\n            </h1>\n            <p class=\"mt-3 text-[15px] text-[#969696] text-center\" data-kid=\"1-2-1-2\" data-name=\"registration description text\">\n                Reserve custom aliases and keep track of every click.\n            </p>\n            <!-- PANEL -->\n            <div class=\"mt-8 max-w-[420px] mx-auto bg-[#1E1E1E] border border-[#2C2C2C] rounded-[24px] p-7\" data-kid=\"1-2-1-3\" data-name=\"registration form container\">\n                <!-- Username -->\n                <div data-kid=\"1-2-1-3-1\" data-name=\"username field group\">\n                    <label class=\"block text-[13px] font-medium text-[#D4D4D4] mb-1.5\" data-kid=\"1-2-1-3-1-1\" data-name=\"username field label\" for=\"reg-username\">\n                        Choose a username\n                    </label>\n                    <div class=\"relative\" data-kid=\"1-2-1-3-1-2\" data-name=\"username input wrapper\">\n                        <span class=\"absolute left-5 top-1/2 -translate-y-1/2 text-[#6B6B6B] text-[16px] flex items-center\" data-kid=\"1-2-1-3-1-2-1\" data-name=\"username icon container\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-1-2-1-1\" data-lucide=\"user\" data-name=\"user icon\">\n                            </i>\n                        </span>\n                        <input class=\"w-full h-12 rounded-full bg-[#171717] border border-[#2C2C2C] pl-12 pr-5 text-[15px] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none focus:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-3-1-2-2\" data-name=\"username text input\" id=\"reg-username\" placeholder=\"e.g. john_doe\" type=\"text\"/>\n                    </div>\n                </div>\n                <!-- Password -->\n                <div class=\"mt-4\" data-kid=\"1-2-1-3-2\" data-name=\"password field group\">\n                    <label class=\"block text-[13px] font-medium text-[#D4D4D4] mb-1.5\" data-kid=\"1-2-1-3-2-1\" data-name=\"password field label\" for=\"reg-password\">\n                        Password\n                    </label>\n                    <div class=\"relative\" data-kid=\"1-2-1-3-2-2\" data-name=\"password input wrapper\">\n                        <span class=\"absolute left-5 top-1/2 -translate-y-1/2 text-[#6B6B6B] text-[16px] flex items-center\" data-kid=\"1-2-1-3-2-2-1\" data-name=\"password icon container\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-2-2-1-1\" data-lucide=\"lock\" data-name=\"lock icon\">\n                            </i>\n                        </span>\n                        <input class=\"w-full h-12 rounded-full bg-[#171717] border border-[#2C2C2C] pl-12 pr-5 text-[15px] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none focus:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-3-2-2-2\" data-name=\"password input field\" id=\"reg-password\" placeholder=\"At least 6 characters\" type=\"password\"/>\n                    </div>\n                    <p class=\"mt-2 pl-1 text-[13px] text-[#6B6B6B]\" data-kid=\"1-2-1-3-2-3\" data-name=\"password requirements help text\">\n                        Use 6+ characters — a passphrase works great.\n                    </p>\n                </div>\n                <!-- PRIMARY CTA -->\n                <button class=\"mt-6 w-full h-12 rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[15px] flex items-center justify-center gap-2\" data-kid=\"1-2-1-3-3\" data-name=\"create account primary button\">\n                    <span data-kid=\"1-2-1-3-3-1\" data-name=\"create account button text\">\n                        Create account\n                    </span>\n                    <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-3-2\" data-lucide=\"arrow-right\" data-name=\"arrow right icon\">\n                    </i>\n                </button>\n                <!-- SUCCESS STATE -->\n                <div class=\"mt-4 rounded-[16px] px-4 py-3 flex items-center gap-2 bg-[rgba(45,212,191,0.08)] border border-[rgba(45,212,191,0.25)]\" data-kid=\"1-2-1-3-4\" data-name=\"form success message container\">\n                    <span class=\"text-[#2DD4BF] text-[16px] flex items-center shrink-0\" data-kid=\"1-2-1-3-4-1\" data-name=\"success icon container\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-4-1-1\" data-lucide=\"circle-check\" data-name=\"check circle icon\">\n                        </i>\n                    </span>\n                    <span class=\"text-[13px] text-[#2DD4BF]\" data-kid=\"1-2-1-3-4-2\" data-name=\"success status message text\">\n                        Account created! Signing you in…\n                    </span>\n                </div>\n                <!-- Divider + login footer -->\n                <div class=\"mt-6 pt-5 border-t border-[#2C2C2C] text-center text-[14px] text-[#969696]\" data-kid=\"1-2-1-3-5\" data-name=\"login footer text\">\n                    Already have an account?\n                    <a class=\"text-[#2DD4BF] font-medium hover:underline\" data-kid=\"1-2-1-3-5-1\" data-name=\"login link\" href=\"#\">\n                        Log in\n                    </a>\n                </div>\n            </div>\n            <p class=\"mt-6 text-center text-[13px] text-[#6B6B6B]\" data-kid=\"1-2-1-4\" data-name=\"registration footer disclaimer text\">\n                Free forever — no credit card, no tracking.\n            </p>\n        </section>\n    </main>\n    <!-- FOOTER (identical to login node) -->\n    <footer class=\"border-t border-[#2C2C2C]\" data-kid=\"1-3\" data-name=\"footer section\">\n        <div class=\"max-w-[1120px] mx-auto px-6 py-6 flex items-center justify-between text-[13px] text-[#6B6B6B]\" data-kid=\"1-3-1\" data-name=\"footer contents container\">\n            <div class=\"flex items-center gap-2\" data-kid=\"1-3-1-1\" data-name=\"footer brand container\">\n                <span class=\"w-5 h-5 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[12px]\" data-kid=\"1-3-1-1-1\" data-name=\"footer brand icon container\">\n                    <i class=\"w-3 h-3\" data-kid=\"1-3-1-1-1-1\" data-lucide=\"link-2\" data-name=\"footer link icon\">\n                    </i>\n                </span>\n                <span class=\"font-[Manrope] font-semibold text-[#969696]\" data-kid=\"1-3-1-1-2\" data-name=\"footer brand name text\">\n                    QuickLink\n                </span>\n            </div>\n            <div class=\"flex items-center gap-5\" data-kid=\"1-3-1-2\" data-name=\"footer links container\">\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-1\" data-name=\"footer shorten link\" href=\"#\">\n                    Shorten\n                </a>\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-2\" data-name=\"footer analytics link\" href=\"#\">\n                    Analytics\n                </a>\n            </div>\n            <span data-kid=\"1-3-1-3\" data-name=\"copyright notice text\">\n                © 2026 QuickLink\n            </span>\n        </div>\n    </footer>\n</div>\n<script>\n    lucide.createIcons();\n</script>\n",
      "comments": [],
      "created": "2026-07-23T12:29:30.407822+00:00",
      "modified": "2026-07-23T12:30:19.434596+00:00",
