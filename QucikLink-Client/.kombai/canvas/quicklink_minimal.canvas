      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@600;700;800&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap');\n</style>\n<script src=\"https://unpkg.com/lucide@latest\">\n</script>\n<div class=\"bg-[#151515] font-['Source_Sans_3'] text-[#F4F4F4] antialiased\" data-kid=\"1\">\n    <!-- NAVBAR -->\n    <nav class=\"max-w-[1120px] mx-auto px-6 py-5 flex items-center justify-between\" data-kid=\"1-1\">\n        <a class=\"flex items-center gap-2.5\" data-kid=\"1-1-1\" href=\"#\">\n            <span class=\"w-8 h-8 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[16px]\" data-kid=\"1-1-1-1\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-1-1-1\" data-lucide=\"link-2\">\n                </i>\n            </span>\n            <span class=\"font-[Manrope] font-bold text-[18px] tracking-tight text-[#F4F4F4]\" data-kid=\"1-1-1-2\">\n                QuickLink\n            </span>\n        </a>\n        <div class=\"flex items-center gap-6\" data-kid=\"1-1-2\">\n            <a class=\"text-[14px] text-[#969696] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-1\" href=\"#\">\n                Analytics\n            </a>\n            <a class=\"text-[14px] text-[#D4D4D4] hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-1-2-2\" href=\"#\">\n                Log in\n            </a>\n            <button class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-1-2-3\">\n                <i class=\"w-4 h-4\" data-kid=\"1-1-2-3-1\" data-lucide=\"sun\">\n                </i>\n            </button>\n            <button class=\"rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[14px] px-4 py-2\" data-kid=\"1-1-2-4\">\n                Sign up\n            </button>\n        </div>\n    </nav>\n    <main data-kid=\"1-2\">\n        <!-- HERO + TOOL -->\n        <section class=\"max-w-[680px] mx-auto px-6 pt-16 pb-14 text-center\" data-kid=\"1-2-1\">\n            <h1 class=\"font-[Manrope] font-extrabold text-[44px] leading-[1.15] tracking-tight text-[#F4F4F4]\" data-kid=\"1-2-1-1\">\n                Paste a long link.\n                <br data-kid=\"1-2-1-1-1\"/>\n                Get a short one.\n            </h1>\n            <p class=\"mt-4 text-[16px] leading-relaxed text-[#969696] max-w-md mx-auto\" data-kid=\"1-2-1-2\">\n                Custom aliases, QR codes, and click counts — free, no account needed.\n            </p>\n            <!-- TOOL PANEL -->\n            <div class=\"mt-10 text-left bg-[#1E1E1E] border border-[#2C2C2C] rounded-[24px] p-6\" data-kid=\"1-2-1-3\">\n                <!-- Segmented tabs -->\n                <div class=\"inline-flex items-center bg-[#171717] border border-[#2C2C2C] rounded-full p-1\" data-kid=\"1-2-1-3-1\">\n                    <button class=\"flex items-center gap-2 rounded-full bg-[#2DD4BF] text-[#052A25] font-semibold text-[14px] px-4 py-2\" data-kid=\"1-2-1-3-1-1\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-1-1-1\" data-lucide=\"link-2\">\n                        </i>\n                        <span data-kid=\"1-2-1-3-1-1-2\">\n                            Shorten link\n                        </span>\n                    </button>\n                    <button class=\"flex items-center gap-2 rounded-full text-[#969696] hover:text-[#F4F4F4] transition-colors text-[14px] px-4 py-2\" data-kid=\"1-2-1-3-1-2\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-1-2-1\" data-lucide=\"qr-code\">\n                        </i>\n                        <span data-kid=\"1-2-1-3-1-2-2\">\n                            QR code\n                        </span>\n                    </button>\n                </div>\n                <!-- Big URL input -->\n                <div class=\"mt-5 relative\" data-kid=\"1-2-1-3-2\">\n                    <span class=\"absolute left-5 top-1/2 -translate-y-1/2 text-[#6B6B6B] text-[16px] flex items-center\" data-kid=\"1-2-1-3-2-1\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-2-1-1\" data-lucide=\"link-2\">\n                        </i>\n                    </span>\n                    <input class=\"w-full h-14 rounded-full bg-[#171717] border border-[#2C2C2C] pl-12 pr-5 text-[15px] text-[#F4F4F4] placeholder-[#6B6B6B] focus:outline-none focus:border-[#2DD4BF] transition-colors\" data-kid=\"1-2-1-3-2-2\" placeholder=\"https://your-very-long-link.com/goes-here\" type=\"text\"/>\n                </div>\n                <!-- Customize row -->\n                <div class=\"mt-3 flex items-center gap-5 px-1 flex-wrap\" data-kid=\"1-2-1-3-3\">\n                    <button class=\"flex items-center gap-1.5 text-[14px] text-[#969696] hover:text-[#D4D4D4] transition-colors\" data-kid=\"1-2-1-3-3-1\">\n                        <span data-kid=\"1-2-1-3-3-1-1\">\n                            Customize\n                        </span>\n                        <i class=\"w-3.5 h-3.5\" data-kid=\"1-2-1-3-3-1-2\" data-lucide=\"chevron-down\">\n                        </i>\n                    </button>\n                    <div class=\"flex items-center gap-1.5 text-[14px]\" data-kid=\"1-2-1-3-3-2\">\n                        <span class=\"text-[#969696]\" data-kid=\"1-2-1-3-3-2-1\">\n                            quicklink.live /\n                        </span>\n                        <span class=\"font-['JetBrains_Mono'] text-[#F4F4F4] border-b border-[#2C2C2C] pb-px\" data-dynamic=\"true\" data-kid=\"1-2-1-3-3-2-2\" data-name=\"custom alias text\" data-reason=\"updated via script based on user input\">\n                            summer-sale\n                        </span>\n                    </div>\n                    <span class=\"ml-auto text-[13px] text-[#969696]\" data-dynamic=\"true\" data-kid=\"1-2-1-3-3-3\" data-name=\"link expiration notice text\" data-reason=\"updated based on user selection\">\n                        Expires: never\n                    </span>\n                </div>\n                <!-- Primary CTA -->\n                <button class=\"mt-5 w-full h-[52px] rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[15px] flex items-center justify-center gap-2\" data-kid=\"1-2-1-3-4\">\n                    <span data-kid=\"1-2-1-3-4-1\">\n                        Shorten link\n                    </span>\n                    <i class=\"w-4 h-4\" data-kid=\"1-2-1-3-4-2\" data-lucide=\"arrow-right\">\n                    </i>\n                </button>\n            </div>\n            <!-- RESULT STATE -->\n            <div class=\"mt-4 text-left bg-[#171717] border border-[#2C2C2C] rounded-[24px] p-5\" data-dynamic=\"true\" data-kid=\"1-2-1-4\" data-name=\"result container\" data-reason=\"injected and shown by script upon link creation\">\n                <div class=\"flex items-center justify-between\" data-kid=\"1-2-1-4-1\">\n                    <span class=\"inline-flex items-center gap-2 rounded-full px-3 py-1 text-[13px] text-[#2DD4BF]\" data-kid=\"1-2-1-4-1-1\" style=\"background: rgba(45,212,191,0.08)\">\n                        <span class=\"w-1.5 h-1.5 rounded-full bg-[#2DD4BF]\" data-kid=\"1-2-1-4-1-1-1\">\n                        </span>\n                        <span data-kid=\"1-2-1-4-1-1-2\">\n                            Link ready\n                        </span>\n                    </span>\n                    <div class=\"flex items-center gap-2\" data-kid=\"1-2-1-4-1-2\">\n                        <button class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-2-1-4-1-2-1\" data-name=\"qr code generator button\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-4-1-2-1-1\" data-lucide=\"qr-code\">\n                            </i>\n                        </button>\n                        <button class=\"w-9 h-9 rounded-full border border-[#2C2C2C] flex items-center justify-center text-[#969696] hover:text-[#F4F4F4] hover:border-[#969696] transition-colors text-[16px]\" data-kid=\"1-2-1-4-1-2-2\" data-name=\"external link button\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-1-4-1-2-2-1\" data-lucide=\"external-link\">\n                            </i>\n                        </button>\n                    </div>\n                </div>\n                <div class=\"mt-4 flex items-center gap-4 flex-wrap\" data-kid=\"1-2-1-4-2\">\n                    <span class=\"font-['JetBrains_Mono'] font-semibold text-[20px] text-[#2DD4BF]\" data-dynamic=\"true\" data-kid=\"1-2-1-4-2-1\" data-name=\"generated short link text\" data-reason=\"populated by script response\">\n                        quicklink.live/summer-sale\n                    </span>\n                    <button class=\"inline-flex items-center gap-2 rounded-full bg-[#2DD4BF] hover:bg-[#5EEAD4] transition-colors text-[#052A25] font-semibold text-[13px] px-3.5 py-1.5\" data-kid=\"1-2-1-4-2-2\" data-name=\"copy link button\">\n                        <i class=\"w-3.5 h-3.5\" data-kid=\"1-2-1-4-2-2-1\" data-lucide=\"copy\">\n                        </i>\n                        <span data-kid=\"1-2-1-4-2-2-2\">\n                            Copy\n                        </span>\n                    </button>\n                </div>\n                <p class=\"mt-3 text-[13px] text-[#969696] truncate\" data-dynamic=\"true\" data-kid=\"1-2-1-4-3\" data-name=\"link metadata status text\" data-reason=\"populated by script response with live metrics\">\n                    → https://example.com/summer-sale  ·  0 clicks  ·  Created just now  ·  Never expires\n                </p>\n            </div>\n        </section>\n        <!-- FEATURE STRIP -->\n        <section class=\"max-w-[880px] mx-auto px-6 py-10\" data-kid=\"1-2-2\">\n            <div class=\"grid grid-cols-3 divide-x divide-[#2C2C2C] text-center\" data-kid=\"1-2-2-1\">\n                <div class=\"px-6\" data-kid=\"1-2-2-1-1\">\n                    <h3 class=\"font-[Manrope] font-semibold text-[15px] text-[#F4F4F4]\" data-kid=\"1-2-2-1-1-1\">\n                        Fast redirects\n                    </h3>\n                    <p class=\"mt-1 text-[14px] text-[#969696]\" data-kid=\"1-2-2-1-1-2\">\n                        Warm links resolve from an edge cache.\n                    </p>\n                </div>\n                <div class=\"px-6\" data-kid=\"1-2-2-1-2\">\n                    <h3 class=\"font-[Manrope] font-semibold text-[15px] text-[#F4F4F4]\" data-kid=\"1-2-2-1-2-1\">\n                        Custom aliases\n                    </h3>\n                    <p class=\"mt-1 text-[14px] text-[#969696]\" data-kid=\"1-2-2-1-2-2\">\n                        Name your link something memorable.\n                    </p>\n                </div>\n                <div class=\"px-6\" data-kid=\"1-2-2-1-3\">\n                    <h3 class=\"font-[Manrope] font-semibold text-[15px] text-[#F4F4F4]\" data-kid=\"1-2-2-1-3-1\">\n                        Click counts\n                    </h3>\n                    <p class=\"mt-1 text-[14px] text-[#969696]\" data-kid=\"1-2-2-1-3-2\">\n                        See every redirect as it happens.\n                    </p>\n                </div>\n            </div>\n        </section>\n        <!-- FAQ -->\n        <section class=\"max-w-[680px] mx-auto px-6 pb-16\" data-kid=\"1-2-3\">\n            <h2 class=\"font-[Manrope] font-bold text-[20px] text-[#F4F4F4] mb-4\" data-kid=\"1-2-3-1\">\n                Questions\n            </h2>\n            <div data-kid=\"1-2-3-2\">\n                <div class=\"border-t border-[#2C2C2C] py-4\" data-dynamic=\"true\" data-kid=\"1-2-3-2-1\" data-name=\"expanded faq item\" data-reason=\"visibility and content toggled by script\">\n                    <div class=\"flex items-center justify-between\" data-kid=\"1-2-3-2-1-1\">\n                        <span class=\"text-[15px] font-medium text-[#D4D4D4]\" data-kid=\"1-2-3-2-1-1-1\">\n                            What is a URL shortener?\n                        </span>\n                        <span class=\"text-[#2DD4BF] text-[16px] flex items-center\" data-dynamic=\"true\" data-kid=\"1-2-3-2-1-1-2\" data-name=\"minus icon\" data-reason=\"toggled by script state\">\n                            <i class=\"w-4 h-4\" data-kid=\"1-2-3-2-1-1-2-1\" data-lucide=\"minus\">\n                            </i>\n                        </span>\n                    </div>\n                    <p class=\"mt-2 pb-2 pr-8 text-[14px] leading-relaxed text-[#969696]\" data-kid=\"1-2-3-2-1-2\">\n                        A URL shortener converts long web links into short addresses that redirect visitors to the original destination.\n                    </p>\n                </div>\n                <div class=\"border-t border-[#2C2C2C] py-4 flex items-center justify-between\" data-kid=\"1-2-3-2-2\">\n                    <span class=\"text-[15px] font-medium text-[#D4D4D4]\" data-kid=\"1-2-3-2-2-1\">\n                        Can I create custom link aliases?\n                    </span>\n                    <span class=\"text-[#969696] text-[16px] flex items-center\" data-dynamic=\"true\" data-kid=\"1-2-3-2-2-2\" data-name=\"plus icon\" data-reason=\"toggled by script state\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-3-2-2-2-1\" data-lucide=\"plus\">\n                        </i>\n                    </span>\n                </div>\n                <div class=\"border-t border-[#2C2C2C] py-4 flex items-center justify-between\" data-kid=\"1-2-3-2-3\">\n                    <span class=\"text-[15px] font-medium text-[#D4D4D4]\" data-kid=\"1-2-3-2-3-1\">\n                        Are QR codes free to download?\n                    </span>\n                    <span class=\"text-[#969696] text-[16px] flex items-center\" data-dynamic=\"true\" data-kid=\"1-2-3-2-3-2\" data-name=\"plus icon\" data-reason=\"toggled by script state\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-3-2-3-2-1\" data-lucide=\"plus\">\n                        </i>\n                    </span>\n                </div>\n                <div class=\"border-t border-[#2C2C2C] py-4 flex items-center justify-between\" data-kid=\"1-2-3-2-4\">\n                    <span class=\"text-[15px] font-medium text-[#D4D4D4]\" data-kid=\"1-2-3-2-4-1\">\n                        How does link expiration work?\n                    </span>\n                    <span class=\"text-[#969696] text-[16px] flex items-center\" data-dynamic=\"true\" data-kid=\"1-2-3-2-4-2\" data-name=\"plus icon\" data-reason=\"toggled by script state\">\n                        <i class=\"w-4 h-4\" data-kid=\"1-2-3-2-4-2-1\" data-lucide=\"plus\">\n                        </i>\n                    </span>\n                </div>\n            </div>\n        </section>\n    </main>\n    <!-- FOOTER -->\n    <footer class=\"border-t border-[#2C2C2C]\" data-kid=\"1-3\">\n        <div class=\"max-w-[1120px] mx-auto px-6 py-6 flex items-center justify-between text-[13px] text-[#6B6B6B]\" data-kid=\"1-3-1\">\n            <div class=\"flex items-center gap-2\" data-kid=\"1-3-1-1\">\n                <span class=\"w-5 h-5 rounded-full bg-[#2DD4BF] flex items-center justify-center text-[#052A25] text-[12px]\" data-kid=\"1-3-1-1-1\">\n                    <i class=\"w-3 h-3\" data-kid=\"1-3-1-1-1-1\" data-lucide=\"link-2\">\n                    </i>\n                </span>\n                <span class=\"font-[Manrope] font-semibold text-[#969696]\" data-kid=\"1-3-1-1-2\">\n                    QuickLink\n                </span>\n            </div>\n            <div class=\"flex items-center gap-5\" data-kid=\"1-3-1-2\">\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-1\" href=\"#\">\n                    Shorten\n                </a>\n                <a class=\"hover:text-[#F4F4F4] transition-colors\" data-kid=\"1-3-1-2-2\" href=\"#\">\n                    Analytics\n                </a>\n            </div>\n            <span data-kid=\"1-3-1-3\">\n                © 2026 QuickLink\n            </span>\n        </div>\n    </footer>\n</div>\n<script>\n    lucide.createIcons();\n</script>\n",
